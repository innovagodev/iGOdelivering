# iGOdelivering - Environment Variables Example
# Copia questo file in .env e inserisci le tue chiavi reali.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI API Keys
OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
PERPLEXITY_API_KEY=your-perplexity-key

# Analytics & Ads
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Payments (OAuth Connect Platform - Server-side only)
# Stripe Connect (Innovago Platform Credentials)
STRIPE_CLIENT_ID=your_stripe_client_id
STRIPE_SECRET_KEY=your_stripe_secret_key

# PayPal Partner (Innovago Platform Credentials)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:4028
